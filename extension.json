			"localBasePath": "resources/experiments/minervaToc",
			"remoteExtPath": "ReaderExperiments/resources/experiments/minervaToc",
			"packageFiles": [
				"initStickyHeader.js"
			],
			"dependencies": [
				"ext.readerExperiments/minervaToc",
				"ext.readerExperiments/minervaToc.instrumentation"
			]
		},
		"ext.readerExperiments/minervaToc.button": {
			"localBasePath": "resources/experiments/minervaToc",
			"remoteExtPath": "ReaderExperiments/resources/experiments/minervaToc",
			"packageFiles": [
				"initFloatingButton.js"
			],
			"dependencies": [
				"ext.readerExperiments/minervaToc",
				"ext.readerExperiments/minervaToc.instrumentation"
			]
		},
		"ext.readerExperiments/lib/html-to-image": {
			"localBasePath": "resources/lib/html-to-image",
			"packageFiles": [
				"html-to-image.js"
			]
		},
		"ext.readerExperiments/shareHighlight": {
